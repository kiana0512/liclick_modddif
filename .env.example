# Local development defaults
SERVER_PORT=4517
SERVER_HOST=127.0.0.1
LICLICK_PUBLIC_WORKSPACE_URL=http://127.0.0.1:4517
LICLICK_PUBLIC_PATH=
LICLICK_FRONTEND_URL=http://127.0.0.1:5173
LICLICK_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
AUTH_MODE=feishu-oauth
SESSION_COOKIE_NAME=liclick_3d_session
SESSION_SECRET=change-me-in-real-env
SESSION_MAX_AGE_DAYS=14
SESSION_COOKIE_SECURE=false

# Preferred login mode: local Atlas gateway + Liclick HttpOnly cookie session.
# Atlas owns the company IDaaS / Feishu authorization flow and writes its local token cache.
LICLICK_ENABLE_ATLAS_LOCAL_LOGIN=true
ATLAS_LOGIN_MODE=interactive
ATLAS_SKILLHUB_PATH=

# Optional IDaaS SP mode. Enable only when IDaaS has registered the Liclick Service URL.
IDAAS_JWT_SSO_ENABLED=false
IDAAS_JWT_SSO_URL=https://idaas.lilith.com/enduser/sp/sso/lilithplugin_jwt57
IDAAS_ENTERPRISE_ID=lilith
# Must be an IDaaS-registered Service URL. 127.0.0.1 will be rejected by IDaaS unless explicitly registered.
IDAAS_SP_SERVICE_URL=

# Optional direct OAuth mode for tests or a non-IDaaS provider.
FEISHU_OAUTH_CLIENT_ID=
FEISHU_OAUTH_CLIENT_SECRET=
FEISHU_OAUTH_AUTHORIZE_URL=
FEISHU_OAUTH_TOKEN_URL=
FEISHU_OAUTH_USERINFO_URL=
FEISHU_OAUTH_REDIRECT_URL=http://127.0.0.1:4517/api/auth/feishu/callback
FEISHU_OAUTH_SCOPE=openid profile email
FEISHU_OAUTH_TOKEN_AUTH_METHOD=client_secret_post
FEISHU_OAUTH_EXTRA_AUTHORIZE_PARAMS=
# Only set true for scripts/smoke-auth-oauth.mjs or an explicitly local mock provider.
FEISHU_OAUTH_ALLOW_LOOPBACK_PROVIDER=false
