{
  "name": "liclick-3d-texture",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Liclick 3D Texture - Web AI 3D texture studio foundation.",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "corepack pnpm --filter @liclick/web dev",
